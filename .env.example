# ==============================================================================
# Katabump Standalone Scheduler & Wake Runner Configuration
# ==============================================================================

# Target website to keep alive
TARGET_URL=https://dososda.containers.snapdeploy.dev

# Cron expression to schedule runs (default: every 7 minutes)
WAKE_CRON=*/7 * * * *

# Timezone for the scheduler and browser runtime (default: UTC)
WAKE_TZ=UTC

# ==============================================================================
# Playwright Browser Flow Settings (Human Simulation)
# ==============================================================================

# Browser locale
WAKE_LOCALE=en-US

# Run browser in headless mode (true / false)
WAKE_HEADLESS=true

# Number of attempts per wake cycle (with jittered backoff)
WAKE_RETRIES=3

# ==============================================================================
# Timeouts (in milliseconds)
# ==============================================================================

# Page navigation timeout
WAKE_NAV_TIMEOUT_MS=30000

# Network idle stabilization timeout (best-effort)
WAKE_NETWORKIDLE_TIMEOUT_MS=7000

# Timeout for individual page actions (clicks, etc.)
WAKE_ACTION_TIMEOUT_MS=8000

# ==============================================================================
# Human-Like Delays & Jitter (in milliseconds)
# ==============================================================================

# Jitter range for minor pauses between page actions
WAKE_JITTER_MIN_MS=250
WAKE_JITTER_MAX_MS=1400

# Backoff configuration between retries
WAKE_RETRY_BASE_MS=1500
WAKE_RETRY_JITTER_MIN_MS=400
WAKE_RETRY_JITTER_MAX_MS=1800

# ==============================================================================
# Interactive Element Simulation
# ==============================================================================

# Mouse movement count range
WAKE_MOUSE_MOVES_MIN=3
WAKE_MOUSE_MOVES_MAX=6

# Page scrolling passes range
WAKE_SCROLL_PASSES_MIN=2
WAKE_SCROLL_PASSES_MAX=5

# Probability of clicking a random interactive element (0.0 to 1.0)
WAKE_INTERACT_PROBABILITY=0.65

# Probability of clicking an internal link, waiting, and navigating back (0.0 to 1.0)
WAKE_LINK_HOP_PROBABILITY=0.5
